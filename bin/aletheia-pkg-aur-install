#!/bin/bash

# Show a fuzzy-finder TUI for picking new AUR packages to install.

aur_helper=$(aletheia-pkg-aur-helper 2>/dev/null) || {
  echo "No AUR helper found (need yay or paru)" >&2
  exit 1
}

fzf_args=(
  --multi
  --preview "$aur_helper -Siia {1}"
  --preview-label='alt-p: toggle description, alt-b/B: toggle PKGBUILD, alt-j/k: scroll, tab: multi-select'
  --preview-label-pos='bottom'
  --preview-window 'down:65%:wrap'
  --bind 'alt-p:toggle-preview'
  --bind 'alt-d:preview-half-page-down,alt-u:preview-half-page-up'
  --bind 'alt-k:preview-up,alt-j:preview-down'
  --bind "alt-b:change-preview:$aur_helper -Gpa {1} | tail -n +5"
  --bind "alt-B:change-preview:$aur_helper -Siia {1}"
  --color 'pointer:green,marker:green'
)

pkg_names=$("$aur_helper" -Slqa | fzf "${fzf_args[@]}")

if [[ -n $pkg_names ]]; then
  # Add aur/ prefix to each package name and convert to space-separated for yay
  source aletheia-sudo-keepalive

  echo "$pkg_names" | sed 's/^/aur\//' | tr '\n' ' ' | xargs "$aur_helper" -S --noconfirm
  sudo updatedb
  aletheia-show-done
fi
