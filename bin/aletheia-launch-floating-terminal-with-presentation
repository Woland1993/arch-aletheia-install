#!/bin/bash

# Launch a floating terminal with the Aletheia logo presentation, then execute the command passed in, and finally end with the aletheia-show-done presentation.
# Used by actions such as Update System.

cmd="$*"
exec setsid uwsm-app -- xdg-terminal-exec --app-id=org.aletheia.terminal --title=Aletheia -e bash -c "aletheia-show-logo; $cmd; if (( \$? != 130 )); then aletheia-show-done; fi"
