#!/bin/bash
set -e

# Reinstall all default Aletheia packages from the stable channel and downgrade any packages that are too new.

# Set the package repository to the stable mirrors
aletheia-refresh-pacman

# Downgrade any packages to the stable setup
sudo pacman -Suu --noconfirm

# Ensure all packages are installed
mapfile -t packages < <(grep -v '^#' "$ALETHEIA_PATH/install/aletheia-base.packages" | grep -v '^$')
sudo pacman -Syu --noconfirm --needed "${packages[@]}"
