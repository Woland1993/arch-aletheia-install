#!/bin/bash

# Update AUR packages if any are installed
aur_helper=$(aletheia-pkg-aur-helper 2>/dev/null) || exit 0

if pacman -Qem >/dev/null; then
  if aletheia-pkg-aur-accessible; then
    echo -e "\e[32m\nUpdate AUR packages\e[0m"
    "$aur_helper" -Sua --noconfirm --cleanafter --ignore gcc14,gcc14-libs
    echo
  else
    echo -e "\e[31m\nAUR is unavailable (so skipping updates)\e[0m"
    echo
  fi
fi
