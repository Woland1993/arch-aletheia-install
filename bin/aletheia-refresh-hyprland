#!/bin/bash

# Overwrite all the user configs in ~/.config/hypr with the Aletheia defaults.

aletheia-refresh-config hypr/autostart.conf
aletheia-refresh-config hypr/bindings.conf
aletheia-refresh-config hypr/input.conf
aletheia-refresh-config hypr/looknfeel.conf
aletheia-refresh-config hypr/hyprland.conf
aletheia-refresh-config hypr/monitors.conf
bash "$ALETHEIA_PATH/install/config/detect-keyboard-layout.sh"
