#!/bin/bash

# Launch or focus on a given TUI identified by the passed in as the command.
# Use by commands like aletheia-launch-wifi to ensure there is only one wifi configuration screen open.

APP_ID="org.aletheia.$(basename "$1")"
LAUNCH_COMMAND="aletheia-launch-tui $@"

exec aletheia-launch-or-focus "$APP_ID" "$LAUNCH_COMMAND"
