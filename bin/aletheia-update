#!/bin/bash

set -e

# Run the update inside a PTY so pacman/yay keep showing download progress
# while still logging the full session for later analysis.
if [[ -z $ALETHEIA_UPDATE_LOGGED ]]; then
  script_command=$(printf '%q ' "$0" "$@")
  exec env ALETHEIA_UPDATE_LOGGED=1 script -qefc "$script_command" "/tmp/aletheia-update.log"
fi

trap 'echo ""; echo -e "\033[0;31mSomething went wrong during the update!\n\nPlease review the output above carefully, correct the error, and retry the update.\033[0m"' ERR

if [[ $1 == "-y" ]] || aletheia-update-confirm; then
  aletheia-snapshot create || (($? == 127))
  aletheia-update-git
  aletheia-update-perform
fi
