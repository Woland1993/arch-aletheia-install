#!/bin/bash

TOGGLE="internal-monitor-disable"

enable() {
  if aletheia-hyprland-toggle-enabled "$TOGGLE"; then
    aletheia-hyprland-toggle --disabled-notification "󰍹    Laptop display enabled" "$TOGGLE"
  fi
}

disable() {
  if aletheia-hw-external-monitors; then
    if aletheia-hyprland-toggle-disabled "$TOGGLE"; then
      aletheia-hyprland-toggle --enabled-notification "󰍹    Laptop display disabled" "$TOGGLE"
    fi
  else
    notify-send -u low "󰍹    Can't disable the only active display"
    exit 1
  fi
}

recover() {
  if ! aletheia-hw-external-monitors && aletheia-hyprland-toggle-enabled "$TOGGLE"; then
    aletheia-hyprland-toggle "$TOGGLE"
  fi
}

case "$1" in
  on) enable ;;
  off) disable ;;
  toggle) if aletheia-hyprland-toggle-enabled "$TOGGLE"; then enable; else disable; fi ;;
  recover) recover ;;
  *)
    echo "Usage: $(basename "$0") {on|off|toggle|recover}" >&2
    exit 1
    ;;
esac
