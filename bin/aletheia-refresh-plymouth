#!/bin/bash

# Overwrite the user config for the Plymouth drive decryption and boot sequence with the Aletheia default and rebuild it.

sudo cp ~/.local/share/aletheia/default/plymouth/* /usr/share/plymouth/themes/aletheia/
sudo plymouth-set-default-theme aletheia

if command -v limine-mkinitcpio &>/dev/null; then
  sudo limine-mkinitcpio
else
  sudo mkinitcpio -P
fi
